# Copy to android/key.properties (DO NOT COMMIT real secrets).
# Generate keystore:
#   keytool -genkeypair -v -keystore driver_pilot-upload.jks -keyalg RSA -keysize 2048 -validity 10000 -alias upload
#
# Put the .jks next to this file (repo root: apps/driver_pilot/) or adjust storeFile path.

storePassword=CHANGE_ME
keyPassword=CHANGE_ME
keyAlias=upload
storeFile=../driver_pilot-upload.jks
